#!/bin/bash
#SBATCH -J vllm_qwen25
#SBATCH -A YOUR_ACCOUNT
#SBATCH -p YOUR_PARTITION
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gpus-per-node=1
#SBATCH --cpus-per-task=16
#SBATCH --mem=128G
#SBATCH --time=24:00:00
#SBATCH -o /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/vllm_%j.out
#SBATCH -e /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/vllm_%j.err

# ── USER CONFIGURATION ────────────────────────────────────────────────────────
MODEL_PATH=/work/jaylin0418/home_models/Qwen2.5-7B-Instruct
PORT=8000
TENSOR_PARALLEL=1
MAX_MODEL_LEN=8192
VLLM_ENV=/path/to/vllm/python   # e.g. ~/miniconda3/envs/vllm/bin/python
# ─────────────────────────────────────────────────────────────────────────────

mkdir -p /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs

echo "=========================================="
echo "Job: vLLM Qwen2.5-7B-Instruct"
echo "Job ID: $SLURM_JOB_ID  Node: $SLURM_NODELIST"
echo "Start: $(date)"
echo "=========================================="

$VLLM_ENV -m vllm.entrypoints.openai.api_server \
    --model "$MODEL_PATH" \
    --tensor-parallel-size "$TENSOR_PARALLEL" \
    --max-model-len "$MAX_MODEL_LEN" \
    --dtype bfloat16 \
    --port "$PORT" \
    --served-model-name "Qwen/Qwen2.5-7B-Instruct" \
    --enable-prefix-caching \
    --trust-remote-code

echo "End: $(date)"
