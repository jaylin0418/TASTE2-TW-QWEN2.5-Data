#!/bin/bash
#SBATCH -J vllm_qwen25
#SBATCH -A mst115022
#SBATCH -p 8gpus
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gpus-per-node=1
#SBATCH --cpus-per-task=16
#SBATCH --mem=128G
#SBATCH --time=48:00:00
#SBATCH -o /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/vllm_%j.out
#SBATCH -e /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/vllm_%j.err

# ── USER CONFIGURATION ────────────────────────────────────────────────────────
MODEL_PATH=/work/jaylin0418/model_merging/models/Qwen2.5-7B-Instruct
PORT=8000
TENSOR_PARALLEL=1
MAX_MODEL_LEN=8192
# vLLM env: bash vllm_server/install_vllm.sh 安裝一次
VLLM_PYTHON=/home/jaylin0418/miniconda3/envs/vllm_py312/bin/python
# ─────────────────────────────────────────────────────────────────────────────

mkdir -p /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs

# Write hostname so gen_text workers can find this server
NODE=$(hostname)
echo "$NODE" > /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/vllm_host.txt
echo "vLLM node: $NODE"

echo "=========================================="
echo "Job: vLLM Qwen2.5-7B-Instruct"
echo "Job ID: $SLURM_JOB_ID  Node: $SLURM_NODELIST"
echo "Start: $(date)"
echo "=========================================="

$VLLM_PYTHON -m vllm.entrypoints.openai.api_server \
    --model "$MODEL_PATH" \
    --tensor-parallel-size "$TENSOR_PARALLEL" \
    --max-model-len "$MAX_MODEL_LEN" \
    --dtype bfloat16 \
    --port "$PORT" \
    --served-model-name "Qwen/Qwen2.5-7B-Instruct" \
    --enable-prefix-caching \
    --trust-remote-code

echo "End: $(date)"
