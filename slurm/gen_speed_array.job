#!/bin/bash
#SBATCH -J gen_speed
#SBATCH -A mst115022
#SBATCH -p ngs62g
#SBATCH --array=0-46
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=16G
#SBATCH --time=12:00:00
#SBATCH -o /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/gen_speed_%A_%a.out
#SBATCH -e /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/gen_speed_%A_%a.err

# ── USER CONFIGURATION ────────────────────────────────────────────────────────
REPO=/work/jaylin0418/TASTE2-TW-QWEN2.5-Data
PYTHON=/home/jaylin0418/miniconda3/envs/vllm_py312/bin/python3
VLLM_PORT=8000
VLLM_HOST=$(cat $REPO/logs/vllm_host.txt 2>/dev/null || echo "localhost")
# speed_ua (基於 user_agent prompt) 或 speed_daily (基於 daily_conv prompt)
SPEED_TYPE=speed_ua
CONFIG=$REPO/conf/speed_control.yaml
OUTPUT=$REPO/output/${SPEED_TYPE}
NUM_SCENARIOS=200
# ─────────────────────────────────────────────────────────────────────────────

TOPICS=(
    "藝術" "書籍" "汽車" "名人" "程式設計" "烹飪" "教育" "活動與展覽"
    "時尚" "健身" "財經" "美食" "電玩遊戲" "園藝" "健康" "歷史"
    "嗜好" "假期旅遊" "居家生活" "語言學習" "彩妝" "電影" "音樂"
    "大自然" "新聞時事" "寵物" "哲學" "攝影" "播客節目" "政治"
    "人際關係" "科學" "購物" "社群媒體" "心靈成長" "運動" "科技"
    "傳統文化" "旅遊" "天氣" "工作職場"
    "台灣夜市文化" "廟宇與民俗信仰" "台灣選舉與公民社會"
    "台灣景點旅遊" "台灣美食文化" "台灣交通日常"
)

TOPIC="${TOPICS[$SLURM_ARRAY_TASK_ID]}"
mkdir -p $REPO/logs $OUTPUT

echo "=========================================="
echo "Job: gen_speed  Array: $SLURM_ARRAY_JOB_ID  Task: $SLURM_ARRAY_TASK_ID"
echo "Topic: $TOPIC  Type: $SPEED_TYPE  vLLM: $VLLM_HOST:$VLLM_PORT"
echo "Start: $(date)"
echo "=========================================="

$PYTHON $REPO/generate/gen_speed_control.py \
    --config "$CONFIG" \
    --type "$SPEED_TYPE" \
    --topic "$TOPIC" \
    --num-scenarios "$NUM_SCENARIOS" \
    --output "$OUTPUT" \
    --vllm-url "http://${VLLM_HOST}:${VLLM_PORT}/v1"

echo "End: $(date)"
