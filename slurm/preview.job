#!/bin/bash
#SBATCH -J preview_samples
#SBATCH -A mst115022
#SBATCH -p dev
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=80G
#SBATCH --gres=gpu:H200:1
#SBATCH --time=01:00:00
#SBATCH -o /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/preview_%j.out
#SBATCH -e /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/preview_%j.err

REPO=/work/jaylin0418/TASTE2-TW-QWEN2.5-Data
PYTHON=/home/jaylin0418/miniconda3/envs/breezyvoice_py310/bin/python3

mkdir -p $REPO/logs

echo "=========================================="
echo "Preview job: $SLURM_JOB_ID  Node: $SLURMD_NODENAME"
echo "Start: $(date)"
echo "=========================================="

$PYTHON $REPO/preview_samples.py --types user_agent daily_conv if_data --seed 123

echo "End: $(date)"
