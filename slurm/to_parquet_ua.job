#!/bin/bash
#SBATCH -J to_parquet_ua
#SBATCH -A mst113234
#SBATCH -p dev
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gpus-per-node=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=04:00:00
#SBATCH -o /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/to_parquet_ua_%j.out
#SBATCH -e /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/to_parquet_ua_%j.err
#SBATCH --dependency=afterok:165423

REPO=/work/jaylin0418/TASTE2-TW-QWEN2.5-Data
PYTHON=/home/jaylin0418/miniconda3/envs/breezyvoice_py310/bin/python3

mkdir -p $REPO/logs $REPO/parquet/user_agent

echo "============================================================"
echo "Job: to_parquet_ua  JobID: $SLURM_JOB_ID"
echo "Start: $(date)"
echo "============================================================"

echo "--- Language filter: user_agent ---"
$PYTHON $REPO/scripts/filter_english_dialogues.py --type user_agent
echo ""

echo "--- Language filter: user_agent_remaining ---"
$PYTHON $REPO/scripts/filter_english_dialogues.py --type user_agent_remaining
echo ""

echo "--- to_parquet: user_agent (Mode B, existing) ---"
$PYTHON $REPO/to_parquet/to_parquet_v5.py \
    --input  $REPO/tts_output/user_agent \
    --output $REPO/parquet/user_agent \
    --prefix user_agent \
    --chunk-gb 1.0
echo ""

echo "--- to_parquet: user_agent_remaining (Mode A, new) ---"
$PYTHON $REPO/to_parquet/to_parquet_v5.py \
    --input  $REPO/tts_output/user_agent_remaining \
    --output $REPO/parquet/user_agent \
    --prefix user_agent_rem \
    --chunk-gb 1.0

echo "============================================================"
echo "to_parquet_ua done. End: $(date)"
echo "============================================================"
