#!/bin/bash
#SBATCH -J tts_speed_ua
#SBATCH -A mst113101
#SBATCH -p 8gpus
#SBATCH --array=0-44
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gpus-per-node=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=24:00:00
#SBATCH -o /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/tts_speed_ua_%A_%a.out
#SBATCH -e /work/jaylin0418/TASTE2-TW-QWEN2.5-Data/logs/tts_speed_ua_%A_%a.err

# ── USER CONFIGURATION ────────────────────────────────────────────────────────
REPO=/work/jaylin0418/TASTE2-TW-QWEN2.5-Data
PYTHON=/home/jaylin0418/miniconda3/envs/breezyvoice_py310/bin/python
INDEXTTS_DIR=/work/jaylin0418/cog-IndexTTS-2
CV_POOL=/work/jaylin0418/common_voice_zh_TW/pool/cv_pool.json
REF_AUDIO_DIR=/home/jaylin0418/SpeechLab/ref_audio/eleven_lab_emotion
BREEZY_REPO=/home/jaylin0418/SpeechLab/tts_model/BreezyVoice
BREEZY_PYTHON=/home/jaylin0418/miniconda3/envs/breezyvoice_py310/bin/python
BREEZY_MODEL=/home/jaylin0418/SpeechLab/tts_model/BreezyVoice/checkpoints/hf_cache/models--MediaTek-Research--BreezyVoice-300M/snapshots/e33b502e0ac21c16b0ee0d00df66ac3fa737393d
INPUT_BASE=$REPO/output/speed_ua
OUTPUT_BASE=$REPO/tts_output/speed_ua
# ─────────────────────────────────────────────────────────────────────────────

TOPICS=(
    "藝術" "書籍" "汽車" "名人" "程式設計" "烹飪" "教育" "活動與展覽"
    "時尚" "健身" "財經" "美食" "電玩遊戲" "園藝" "健康" "歷史"
    "嗜好" "假期旅遊" "居家生活" "語言學習" "彩妝" "電影" "音樂"
    "大自然" "新聞時事" "寵物" "哲學" "攝影" "播客節目" "政治"
    "人際關係" "科學" "購物" "社群媒體" "心靈成長" "運動" "科技"
    "傳統文化" "旅遊" "天氣" "工作職場"
    "台灣文化" "台灣旅遊" "台灣社會" "台灣民俗信仰"
)

TOPIC="${TOPICS[$SLURM_ARRAY_TASK_ID]}"
INPUT=$INPUT_BASE/dialogues_${TOPIC}.jsonl
OUTPUT=$OUTPUT_BASE/${TOPIC}

mkdir -p $REPO/logs $OUTPUT

echo "=========================================="
echo "Job: tts_speed_ua  Topic: $TOPIC"
echo "Job ID: $SLURM_JOB_ID  Node: $SLURM_NODELIST"
echo "Input: $INPUT"
echo "Start: $(date)"
echo "=========================================="

export PYTHONPATH=$INDEXTTS_DIR:$REPO:$PYTHONPATH

$PYTHON $REPO/tts/tts_runner.py \
    --input         "$INPUT" \
    --output        "$OUTPUT" \
    --config        $REPO/conf/base.yaml \
    --indextts-dir  $INDEXTTS_DIR \
    --cv-pool       $CV_POOL \
    --ref-audio-dir $REF_AUDIO_DIR \
    --breezy-repo   $BREEZY_REPO \
    --breezy-python $BREEZY_PYTHON \
    --breezy-model  $BREEZY_MODEL \
    --worker-id 0 --num-workers 1

echo "End: $(date)"
